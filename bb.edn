{:paths ["src" "test"]
 :tasks
 {:requires ([epp.pipeline.metadata :as metadata]
             [epp.pipeline.episode-page :as episode-page]
             [epp.pipeline.manifest :as manifest]
             [epp.pipeline.merge :as merge]
             [epp.pipeline.transcribe :as transcribe]
             [epp.pipeline.validation :as validation])
  extract-metadata {:doc "Write sources/episode-selected.json from sources/episode-selected.xml."
                    :task (metadata/extract!)}
  build-chunks-manifest {:doc "Write audio/chunks-manifest.json from audio/chunks/*.mp3."
                         :task (manifest/build!)}
  merge-transcripts {:doc "Write combined diarized JSON and final markdown transcript."
                     :task (merge/merge!)}
  transcribe-chunks {:doc "Transcribe audio chunks with OpenAI's diarized transcription API."
                     :task (apply transcribe/-main *command-line-args*)}
  generate-episode-page {:doc "Write the static episode page and public transcript assets."
                         :task (apply episode-page/-main *command-line-args*)}
  validate-outputs {:doc "Write transcripts/combined/validation-report.json and fail on validation errors."
                    :task (validation/validate!)}
  test {:doc "Run Babashka pipeline tests."
        :task ((requiring-resolve 'epp.pipeline-test-runner/-main))}}}
